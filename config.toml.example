# ╔══════════════════════════════════════════════════════════╗
# ║  流量分析系统 (Traffic Analysis) — 配置文件              ║
# ║  Config format: TOML                                     ║
# ╚══════════════════════════════════════════════════════════╝

[backend]
provider = "deepseek"
model = "deepseek-chat"
api_key = ""
# base_url = ""

[analysis]
temperature = 0.1
max_tokens_dispatch = 300
max_tokens_synthesis = 600
input_max_chars = 3000

[daemon]
watch_dir = "./data"
interval = 30
max_per_scan = 20

[experts]
beacon_detector = true
dns_tunnel = true
port_scan = true
icmp_tunnel = true
payload_analysis = true
threat_intel = true

[logging]
level = "INFO"
file_dir = "./logs"

[local_model]
base_url = "http://localhost:11434/v1"
model = "qwen2.5:1.5b"
concurrency = 200

[pipeline]
input_dir = "./input"
output_dir = "./output"
max_api_calls_per_file = 50
